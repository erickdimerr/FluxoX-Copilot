  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "@fastify/cors": "^9.0.1",
    "@prisma/client": "^6.19.3",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "prisma": "^6.19.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.2",
    "@types/uuid": "^9.0.8",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  }
}
