{
  "info": {
    "name": "FluxoX — Webhook Tests",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:3001" },
    { "key": "token", "value": "COLE_SEU_TOKEN_AQUI" }
  ],
  "item": [
    {
      "name": "0. Obter URLs de Webhook",
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/integration",
        "description": "Retorna as URLs por plataforma e o mapeamento de eventos. Copie o token da URL e cole na variável 'token' da collection."
      }
    },
